<component>
	<previews>
		<preview width="1024" height="600" style_bg_color="0x000000" />
	</previews>

	<api>
		<prop name="text" type="string" default="BTN" />
		<prop name="color" type="color" default="0xbb0d0d" />
		<prop name="color_checked" type="color" default="0x05e804" />
		<prop name="height" type="int" default="48" />
		<prop name="width" type="int" default="120" />
	</api>

	<styles>
		<style name="style_homed" bg_color="0x22c55e" />
	</styles>
	<view
		extends="lv_button"
		style_bg_color="$color"
		style_bg_color-checked="$color_checked"
		name="button"
		height="$height"
		width="$width"
	>
		<style name="style_homed" selector="user_1" />
		<lv_label name="label" align="center" recolor="false" text="$text" />
	</view>
</component>
