<screen>
	<styles>
		<style name="style_tv" bg_color="0x0f172a" bg_opa="100%" />
		<style name="style_tabbar_bg" bg_color="0x0f172a" border_side="top" border_width="2" border_color="0x343f5a" />
		<style name="style_tabbar_btn" bg_color="0x0f172a" text_color="0x3b6ce9" border_width="0" pad_all="0" />
		<style
			name="style_tabbar_btn_checked"
			bg_color="0x192748"
			bg_opa="100%"
			border_width="0"
			pad_all="0"
			text_color="0xb3c8fc"
		/>

		<style name="style_card" bg_color="0x1e293b" bg_opa="100%" radius="12" pad_all="20" border_width="0" />
		<style name="style_card_title" text_color="0x94a3b8" text_letter_space="1" pad_bottom="4" />
		<style name="style_pump_value" text_color="0x60a5fa" />
		<style name="style_pump_off" text_color="0x64748b" />
	</styles>

	<view>
		<lv_tabview tab_bar_position="bottom" align="center" active="0">
			<style name="style_tv" />
			<lv_tabview-tab_bar height="48">
				<style name="style_tabbar_bg" />
			</lv_tabview-tab_bar>
			<lv_tabview-tab text="Preparation" scrollable="false">
				<lv_obj width="300" height="515">
					<style name="style_card" />
					<lv_label text="Controle Valve">
						<style name="style_card_title" />
					</lv_label>
				</lv_obj>

				<toggle_button name="valve_auto_btn" y="75" x="30" height="80" width="80" text="&#xF074;">
					<event_cb trigger="pressed" callback="mon_callback_1" />
				</toggle_button>
				<button name="valve_home_btn" y="205" x="30" height="80" width="80" text="&#xF015;">
					<event_cb trigger="pressed" callback="mon_callback_1" />
				</button>
				<toggle_button name="valve_en_btn" height="80" width="80" y="335" x="30" text="&#xF0E7;">
					<event_cb trigger="pressed" callback="mon_callback_1" />
				</toggle_button>

				<control_slider name="valve_slider" bind_value="valve_target" y="70" x="160" height="350">
					<event_cb trigger="value_changed" callback="slider_update_callback" />
				</control_slider>

				<position_scale
					name="valve_position_scale"
					x="25"
					height="40"
					value_subject="valve_pose"
					y="450"
					width="250"
					label_show="false"
				/>

				<!-- Vacuum pump section -->
				<lv_obj x="320" y="0" width="380" height="515">
					<style name="style_card" />
					<lv_label text="Pompe a vide">
						<style name="style_card_title" />
					</lv_label>
				</lv_obj>

				<!-- Enable / disable pump (manual mode only) -->
				<toggle_button name="pump_en_btn" y="75" x="345" height="90" width="90" text="&#xF011;">
					<event_cb trigger="pressed" callback="pump_enable_callback" />
				</toggle_button>

				<!-- Current pressure readout -->
				<lv_label text="CURRENT PRESSURE" x="460" y="80">
					<style name="style_card_title" />
				</lv_label>
				<lv_label name="pump_pressure_value" x="460" y="100" width="220" bind_text="pump_pressure_text">
					<style name="style_pump_value" />
				</lv_label>

				<!-- Target pressure setpoint (tap to open numeric keypad) -->
				<lv_label text="TARGET PRESSURE" x="345" y="195">
					<style name="style_card_title" />
				</lv_label>
				<bound_button
					name="pump_target_btn"
					x="345"
					y="217"
					width="180"
					height="56"
					color="0x334155"
					text_subject="pump_target_text"
				>
					<event_cb trigger="clicked" callback="pump_target_keypad_open" />
				</bound_button>

				<!-- Current pressure vs. full 0-101.3 kPa chamber range -->
				<position_scale
					name="pump_pressure_scale"
					x="345"
					y="435"
					height="60"
					width="340"
					min="0"
					max="10"
					value_subject="pump_pressure"
					major_tick_every="2"
				/>
			</lv_tabview-tab>

			<lv_tabview-tab text="Stats" scrollable="false">
				<lv_chart
					width="582"
					height="366"
					align="center"
					type="line"
					point_count="6"
					hor_div_line_count="5"
					ver_div_line_count="6"
					x="-110"
					y="44"
				>
					<!-- Fix the primary Y axis range so both series share a scale -->
					<lv_chart-axis axis="primary_y" min_value="0" max_value="100" />

					<!-- Two data series -->
					<lv_chart-series color="0x3b82f6" axis="primary_y" values="20 45 30 70 55 90" />
					<lv_chart-series color="0xf59e0b" axis="primary_y" values="80 60 65 40 50 25" />

					<!-- A cursor showing on a line -->
					<lv_chart-cursor color="0xef4444" dir="hor" pos_y="70" />
				</lv_chart>
			</lv_tabview-tab>

			<lv_tabview-tab text="About" scrollable="false">
				<lv_label text="Tab view organizes content into pages." width="100%">
					<style name="style_card" />
				</lv_label>
			</lv_tabview-tab>
			<lv_tabview-tab_bar height="48">
				<style name="style_tabbar_bg" />
			</lv_tabview-tab_bar>
			<lv_tabview-tab_button index="0">
				<style name="style_tabbar_btn" />
				<style name="style_tabbar_btn_checked" selector="checked" />
			</lv_tabview-tab_button>

			<lv_tabview-tab_button index="1">
				<style name="style_tabbar_btn" />
				<style name="style_tabbar_btn_checked" selector="checked" />
			</lv_tabview-tab_button>

			<lv_tabview-tab_button index="2">
				<style name="style_tabbar_btn" />
				<style name="style_tabbar_btn_checked" selector="checked" />
			</lv_tabview-tab_button>
		</lv_tabview>
	</view>
</screen>
