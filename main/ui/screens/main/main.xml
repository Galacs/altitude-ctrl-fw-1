<screen>
	<styles>
		<style name="style_tv" bg_color="0x0f172a" bg_opa="100%" />
		<style name="style_tabbar_bg" bg_color="0x0f172a" border_side="top" border_width="2" border_color="0x343f5a" />
		<style name="style_tabbar_btn" bg_color="0x0f172a" text_color="0x3b6ce9" border_width="0" pad_all="0" />
		<style
			name="style_tabbar_btn_checked"
			bg_color="0x192748"
			bg_opa="100%"
			border_width="0"
			pad_all="0"
			text_color="0xb3c8fc"
		/>

		<style name="style_card" bg_color="0x1e293b" bg_opa="100%" radius="12" pad_all="20" border_width="0" />
		<style name="style_card_title" text_color="0x94a3b8" text_letter_space="1" pad_bottom="4" />
		<style name="style_pump_value" text_color="0x60a5fa" />
		<style name="style_pump_off" text_color="0x64748b" />
		<style
			name="style_dropdown"
			bg_color="0x0f172a"
			bg_opa="100%"
			text_color="0xffffff"
			border_color="0x334155"
			border_width="1"
			radius="8"
		/>
	</styles>

	<view>
		<lv_tabview tab_bar_position="bottom" align="center" active="0">
			<style name="style_tv" />
			<lv_tabview-tab_bar height="48">
				<style name="style_tabbar_bg" />
			</lv_tabview-tab_bar>
			<lv_tabview-tab text="Preparation" scrollable="false">
				<lv_obj width="300" height="515">
					<style name="style_card" />
					<lv_label text="Controle Valve">
						<style name="style_card_title" />
					</lv_label>
				</lv_obj>

				<toggle_button name="valve_auto_btn" y="75" x="30" height="80" width="80" text="&#xF074;">
					<event_cb trigger="pressed" callback="mon_callback_1" />
				</toggle_button>
				<lv_label name="home_value" x="60" y="180" width="220" bind_text="home_value_text">
					<style name="style_pump_value" />
				</lv_label>
				<button name="valve_home_btn" y="205" x="30" height="80" width="80" text="&#xF015;">
					<event_cb trigger="pressed" callback="valve_home_cb" />
				</button>
				<toggle_button name="valve_en_btn" height="80" width="80" y="335" x="30" text="&#xF0E7;">
					<event_cb trigger="pressed" callback="valve_en_cb" />
				</toggle_button>

				<control_slider name="valve_slider" bind_value="valve_target" y="70" x="160" height="350">
					<event_cb trigger="value_changed" callback="slider_update_callback" />
				</control_slider>

				<position_scale
					name="valve_position_scale"
					x="25"
					height="40"
					value_subject="valve_pose"
					y="450"
					width="250"
					label_show="false"
				/>

				<!-- Vacuum pump section -->
				<lv_obj x="320" y="365" width="500" height="150">
					<style name="style_card" />
					<lv_label text="Pompe a vide">
						<style name="style_card_title" />
					</lv_label>
				</lv_obj>

				<!-- Enable / disable pump (manual mode only) -->
				<toggle_button name="pump_en_btn" y="433" x="710" height="60" width="90" text="&#xF011;">
					<event_cb trigger="pressed" callback="pump_enable_callback" />
				</toggle_button>

				<!-- Current pressure readout -->
				<lv_label text="Pression actuelle: " x="340" y="409">
					<style name="style_card_title" />
				</lv_label>
				<lv_label name="pump_pressure_value" x="495" y="409" width="220" bind_text="pump_pressure_text">
					<style name="style_pump_value" />
				</lv_label>

				<!-- Target pressure setpoint (tap to open numeric keypad) -->
				<lv_label text="Cible: " x="645" y="395">
					<style name="style_card_title" />
				</lv_label>
				<bound_button
					name="pump_target_btn"
					x="710"
					y="380"
					width="90"
					height="40"
					color="0x334155"
					text_subject="pump_target_text"
				>
					<event_cb trigger="clicked" callback="pump_target_keypad_open" />
				</bound_button>

				<!-- Current pressure vs. full 0-101.3 kPa chamber range -->
				<position_scale
					name="pump_pressure_scale"
					x="335"
					y="435"
					height="60"
					width="355"
					min="10"
					max="110"
					value_subject="pump_pressure"
					major_tick_every="4"
				/>

				<!-- Température -->
				<lv_obj x="840" y="365" width="150" height="150">
					<style name="style_card" />
					<lv_label text="Temperature">
						<style name="style_card_title" />
					</lv_label>
				</lv_obj>
				<position_scale
					name="temperature_scale"
					x="850"
					y="400"
					style_bg_opa="0"
					mode="round_inner"
					height="130"
					width="130"
					min="10"
					max="70"
					value_subject="temperature"
					major_tick_every="5"
				/>

				<lv_chart
					name="monitor_chart"
					x="345"
					y="15"
					width="630"
					height="310"
					type="line"
					hor_div_line_count="5"
					ver_div_line_count="6"
					style_bg_color="0x0f172a"
					style_bg_opa="100%"
					style_border_color="0x334155"
					style_border_width="1"
					style_pad_all="0"
					style_radius="0"
				/>
				<position_scale
					name="monitor_y_axis"
					x="215"
					y="15"
					style_bg_opa="0"
					mode="vertical_left"
					height="310"
					width="130"
					min="10"
					max="110"
					min_value="0"
					max_value="0"
					value_subject="zero_int_subject"
					major_tick_every="5"
					text_src="10k 35k 60k 85k 110k"
					style_pad_all="0"
				/>
				<position_scale
					name="monitor_x_axis"
					x="345"
					y="325"
					style_bg_opa="0"
					mode="horizontal_bottom"
					height="60"
					width="630"
					min="10"
					max="110"
					min_value="0"
					max_value="0"
					value_subject="zero_int_subject"
					major_tick_every="4"
					style_pad_all="0"
					text_src="-50m -40m -30m -20m -10m 0"
				/>
			</lv_tabview-tab>

			<lv_tabview-tab text="Stats" scrollable="false">
				<lv_obj x="0" y="0" width="340" height="325">
					<style name="style_card" />
					<lv_label text="Selection profil">
						<style name="style_card_title" />
					</lv_label>
				</lv_obj>

				<lv_obj name="profile_explorer_container" x="20" y="55" width="300" height="250" style_pad_all="3">
					<style name="style_dropdown" />
				</lv_obj>

				<lv_obj x="0" y="340" width="340" height="170">
					<style name="style_card" />
					<lv_label text="Jouer le profil">
						<style name="style_card_title" />
					</lv_label>
				</lv_obj>

				<button name="run_start_btn" x="30" y="390" width="70" height="70" text="&#xF04B;">
					<style name="style_card" />
					<event_cb trigger="clicked" callback="run_start_cb" />
				</button>
				<button name="run_pause_btn" x="130" y="390" width="70" height="70" text="&#xF04C;">
					<style name="style_card" />
					<event_cb trigger="clicked" callback="run_pause_resume_cb" />
				</button>
				<button name="run_stop_btn" x="230" y="390" width="70" height="70" text="&#xF04D;">
					<style name="style_card" />
					<event_cb trigger="clicked" callback="run_stop_cb" />
				</button>
				<lv_label name="run_state_label" text="Pret" x="35" y="475">
					<style name="style_pump_value" />
				</lv_label>
				<lv_label name="run_elapsed_label" text="00:00 / 00:00" x="200" y="480">
					<style name="style_card_title" />
				</lv_label>

				<lv_chart
					name="profile_preview_chart"
					x="400"
					y="20"
					width="580"
					height="470"
					type="scatter"
					hor_div_line_count="5"
					ver_div_line_count="6"
					style_bg_color="0x0f172a"
					style_bg_opa="100%"
					style_border_color="0x334155"
					style_border_width="1"
					style_pad_all="0"
					style_radius="0"
				/>
				<position_scale
					name="preview_y_axis"
					x="270"
					y="20"
					style_bg_opa="0"
					mode="vertical_left"
					height="470"
					width="130"
					min="10"
					max="110"
					min_value="0"
					max_value="0"
					value_subject="zero_int_subject"
					text_src="10k 35k 60k 85k 110k"
					major_tick_every="5"
					style_pad_all="0"
				/>
				<position_scale
					name="preview_x_axis"
					x="400"
					y="490"
					style_bg_opa="0"
					mode="horizontal_bottom"
					height="60"
					width="580"
					min="10"
					max="110"
					min_value="0"
					max_value="0"
					value_subject="zero_int_subject"
					major_tick_every="4"
					style_pad_all="0"
				/>
			</lv_tabview-tab>

			<lv_tabview-tab text="Export" scrollable="false">
				<lv_obj x="20" y="0" width="960" height="60">
					<style name="style_card" />
					<lv_label text="Journaux de cycles (CSV, ecrits automatiquement sur la carte SD)">
						<style name="style_card_title" />
					</lv_label>
				</lv_obj>

				<!-- Empty mount point - the lv_file_explorer widget itself is
				     created from C (export_ui_init), same pattern as
				     profile_explorer_container on the Stats tab. -->
				<lv_obj name="export_explorer_container" x="20" y="80" width="960" height="380">
					<style name="style_dropdown" />
				</lv_obj>

				<button name="export_delete_btn" x="20" y="470" width="150" height="45" text="Supprimer">
					<style name="style_card" />
					<event_cb trigger="clicked" callback="export_delete_selected_cb" />
				</button>
			</lv_tabview-tab>

			<lv_tabview-tab text="Vide" scrollable="false" />

			<lv_tabview-tab text="A propos" scrollable="false">
				<lv_label text="Tab view organizes content into pages." width="100%">
					<style name="style_card" />
				</lv_label>
			</lv_tabview-tab>
			<lv_tabview-tab_bar height="48">
				<style name="style_tabbar_bg" />
			</lv_tabview-tab_bar>
			<lv_tabview-tab_button index="0">
				<style name="style_tabbar_btn" />
				<style name="style_tabbar_btn_checked" selector="checked" />
			</lv_tabview-tab_button>

			<lv_tabview-tab_button index="1">
				<style name="style_tabbar_btn" />
				<style name="style_tabbar_btn_checked" selector="checked" />
			</lv_tabview-tab_button>

			<lv_tabview-tab_button index="2">
				<style name="style_tabbar_btn" />
				<style name="style_tabbar_btn_checked" selector="checked" />
			</lv_tabview-tab_button>

			<lv_tabview-tab_button index="3">
				<style name="style_tabbar_btn" />
				<style name="style_tabbar_btn_checked" selector="checked" />
			</lv_tabview-tab_button>

			<lv_tabview-tab_button index="4">
				<style name="style_tabbar_btn" />
				<style name="style_tabbar_btn_checked" selector="checked" />
			</lv_tabview-tab_button>
		</lv_tabview>
	</view>
</screen>
